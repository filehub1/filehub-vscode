{
  "name": "filehub-vscode",
  "displayName": "FileHub",
  "description": "Instant file search and preview for VSCode",
  "version": "1.0.2",
  "publisher": "exiahuang",
  "repository": {
    "type": "git",
    "url": "https://github.com/filehub1/filehub-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": ["onCommand:filehub.open"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "filehub.open",
        "title": "FileHub: Open"
      }
    ],
    "keybindings": [
      {
        "command": "filehub.open",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f"
      }
    ],
    "configuration": {
      "title": "FileHub",
      "properties": {
        "filehub.indexEngine": {
          "type": "string",
          "enum": ["auto", "win-api", "nodejs"],
          "enumDescriptions": [
            "Auto: use Win32 native API on Windows, fallback to Node.js (fdir)",
            "Win32 API: always use native filehub_addon (Windows only)",
            "Node.js: always use fdir (cross-platform)"
          ],
          "default": "auto",
          "description": "File indexing engine."
        },
        "filehub.indexedDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Directories to index. Defaults to workspace folders."
        },
        "filehub.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "dist",
            "build",
            ".cache",
            "*.log"
          ],
          "description": "Patterns to exclude from indexing."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "build:addon": "cd ../filehub-server/src/addon && npm install && npx node-gyp rebuild",
    "build:full": "npm run build:addon && xcopy /Y /I ..\\filehub-server\\src\\addon\\build\\Release\\filehub_addon.node addon\\ && npm run build",
    "watch": "tsup --watch",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "fdir": "^6.5.0",
    "js-yaml": "^4.1.1",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/yauzl": "^2.10.3",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
}
